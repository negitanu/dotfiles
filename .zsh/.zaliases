## ----------------------------------------------------------------------------
## file    : .zaliases
## brief   : zsh aliases configuration file.
## module  : .zsh
##
## author  : Teppei Kobayashi <tkobayashi@kirisame.tech>
## date    : 2018/01/28
## ----------------------------------------------------------------------------


## ----------------------------------------------------------------------------
## brief   : common aliases.
## note    : -
## ----------------------------------------------------------------------------
alias cd='pushd'
alias pd='popd'
alias open='xdg-open'
alias mkdir='mkdir -p'
alias home='cd ${HOME}'
alias pbcopy='xsel --clipboard --input'
alias pbpaste='xsel --clipboard --output'


## ----------------------------------------------------------------------------
## brief   : command aliases.
## note    : -
## ----------------------------------------------------------------------------
# alias ls="ls -F --color=auto --group-directories-first"
# alias la="ls -A"
# alias ll="ls -lh"
# alias lla="ls -Alh"
# alias lal="lla"
# alias tree="tree -F -C --dirsfirst"
# alias grep="grep -n -T -i --color=always"

# ls aliases
alias ls="eza --color=auto --group-directories-first"
alias la="eza -a"
alias ll="eza -lh"
alias lla="eza -Alh"
alias lal="lla"
alias tree="eza -T -C --dirsfirst"
alias grep="grep -n -T -i --color=always"

# cat aliases
alias cat="bat --paging=never"
